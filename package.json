{
  "name": "parcel-flow",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --nextjs-plugin --deny-warnings .",
    "lint:fix": "oxlint --nextjs-plugin --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
    "dev:db:generate": "drizzle-kit generate --config ./drizzle.config.development.ts",
    "dev:db:migrate": "drizzle-kit migrate --config ./drizzle.config.development.ts",
    "dev:db:push": "drizzle-kit push --config ./drizzle.config.development.ts",
    "dev:db:studio": "drizzle-kit studio --config ./drizzle.config.development.ts",
    "dev:db:seed": "pnpm exec tsx src/db/seeds/seed-super-admin.ts development",
    "prod:db:generate": "drizzle-kit generate --config ./drizzle.config.production.ts",
    "prod:db:migrate": "drizzle-kit migrate --config ./drizzle.config.production.ts",
    "prod:db:push": "drizzle-kit push --config ./drizzle.config.production.ts",
    "prod:db:studio": "drizzle-kit studio --config ./drizzle.config.production.ts",
    "prod:db:seed": "pnpm exec tsx src/db/seeds/seed-super-admin.ts production",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@opennextjs/cloudflare": "^1.17.1",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.5",
    "postgres": "^3.4.8",
    "react": "19.1.5",
    "react-dom": "19.1.5",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5.7.4",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4",
    "wrangler": "^4.76.0"
  },
  "packageManager": "pnpm@10.17.1"
}
